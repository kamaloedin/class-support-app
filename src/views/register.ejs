<div class="row justify-content-center align-items-center ">
    <div class="col-6 text-white">
        <div class="mt-5 mb-5 text-center text-white">
            <h1 class=" fw-bold">Register New User</h1>
        </div>
        <form action="/register" method="post">
            <% if (typeof validationErrors != 'undefined') { %>
                <div class="alert alert-danger" role="alert">
                  <ul>
                    <% validationErrors.forEach(error => { %>
                    <li><%= error.msg %></li>
                    <% }) %>
                  </ul>
                </div>
                <% } %>
            <label for="empId" class="form-label">Employee ID | Name</label>
            <select class="form-select mb-3" id="empId" name="empId" aria-label="register select" required>
                <option selected>Open this select menu</option>
                <% employees.forEach(employee => { %>
                    <option value="<%= employee.id %>"><%= employee.id %> | <%= employee.name %></option>
                <% }) %>
              </select>
            <div class="mb-3">
                <label for="username" class="form-label">Username</label>
                <input type="text" class="form-control" id="username" name="username" min="6" required>
            </div>
            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <input type="password" class="form-control" id="password" name="password" required>
            </div>
            <div class="mb-3">
            <% if (messages.error) { %>
             <%= messages.error %>
            <% } %>
            </div>
            <button type="submit" class="btn btn-primary mb-3">Register</button>
        </form>
    </div>
</div>
<script>
    document.addEventListener("DOMContentLoaded", function() {
        var elements = document.getElementsByTagName("INPUT");
        for (var i = 0; i < elements.length; i++) {
            elements[i].oninvalid = function(e) {
                e.target.setCustomValidity("");
                if (!e.target.validity.valid) {
                    e.target.setCustomValidity("This field cannot be left blank");
                }
            };
            elements[i].oninput = function(e) {
                e.target.setCustomValidity("");
            };
        }
    })    
</script>